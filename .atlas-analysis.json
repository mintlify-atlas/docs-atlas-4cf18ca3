  "keyFeatures": [
    "SvelteKit-based website with SSR and Cloudflare Workers deployment",
    "Events page powered by Google Calendar API",
    "Blog powered by GitHub Discussions",
    "Team/board member directory with dynamic data from JSON",
    "LeetCode Dailies leaderboard and season tracking",
    "Boardify Discord slash command integration for board member updates",
    "Shorter URL shortlink management via Discord",
    "Branding assets and design gallery",
    "Workshops listing by team",
    "Hackathons page",
    "RSS feed and sitemap generation",
    "QR code generation and link shortening"
  ],
  "publicApiSurface": [
    "GET /events - Events listing page",
    "GET /events/[query].json - Events data API",
    "GET /blog - Blog listing page",
    "GET /blog/[id] - Individual blog post",
    "GET /blog/[id].txt - Blog post as plain text",
    "GET /blog/[query].json - Blog data API",
    "GET /teams - Board member directory",
    "GET /workshops/[team] - Workshops by team",
    "GET /hackathons - Hackathons listing",
    "GET /lc-dailies - LeetCode Dailies leaderboard",
    "GET /lc-dailies/[season_id] - Season-specific leaderboard",
    "GET /branding - Branding assets page",
    "GET /boardify - Boardify Discord integration info",
    "GET /shorter - URL shortlink manager info",
    "GET /feed.xml - RSS feed",
    "GET /sitemap - Sitemap",
    "GET /[...id=link].svg - Dynamic SVG via shortlink",
    "GET /[x+40][username] - User profile redirect"
  ]
}
